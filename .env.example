# Application
APP_PORT=3001
APP_ENV=development
APP_NAME=eproject-api
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Supabase Storage
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=eproject-files

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Mail Provider ────────────────────────────────
# Provider: smtp | sendgrid | aws_ses | gcp
MAIL_PROVIDER=smtp
MAIL_FROM_NAME=eProject
MAIL_FROM_ADDRESS=noreply@eproject.com

# SMTP (MAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# SendGrid (MAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# AWS SES (MAIL_PROVIDER=aws_ses)
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1

# GCP (MAIL_PROVIDER=gcp)
GCP_PROJECT_ID=
GCP_CLIENT_EMAIL=
GCP_PRIVATE_KEY=

# Frontend URL
FRONTEND_URL=http://localhost:3000
